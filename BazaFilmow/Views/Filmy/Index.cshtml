@model IEnumerable<BazaFilmow.Models.Film>

@{
    ViewData["Title"] = "Katalog Filmów";
}

<h2>Lista filmów</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj nowy film</a>
</p>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Okładka</th>
            <th>Tytuł</th>
            <th>Długość</th>
            <th>Reżyser</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(film.SciezkaOkladki))
                    {
                        <img src="@film.SciezkaOkladki" alt="Okładka @film.Tytul" style="max-width: 80px; max-height: 120px; object-fit: cover;" class="img-thumbnail" />
                    }
                    else
                    {
                        <span class="text-muted small">Brak okładki</span>
                    }
                </td>
                <td>@film.Tytul</td>
                <td>@film.Dlugosc min</td>
                <td>@film.Rezyser</td>
                <td>
                    <a asp-action="Details" asp-route-id="@film.Id" class="btn btn-info btn-sm">Szczegóły</a>
                    <a asp-action="Edit" asp-route-id="@film.Id" class="btn btn-warning btn-sm">Edytuj</a>
                    <a asp-action="Delete" asp-route-id="@film.Id" class="btn btn-danger btn-sm">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>